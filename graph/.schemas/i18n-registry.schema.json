{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://f2x.local/schemas/i18n-registry.schema.json",
  "title": "i18n-registry",
  "description": "Registry of existing i18n keys across MFE/Shell projects. Used by the agent to avoid hallucinating keys.",
  "type": "object",
  "required": ["_meta", "projects"],
  "properties": {
    "_meta": { "$ref": "https://f2x.local/schemas/specs-graph.schema.json#/$defs/meta" },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "root", "keys"],
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["mfe", "shell", "ds"] },
          "root": { "type": "string" },
          "files": { "type": "array", "items": { "type": "string" } },
          "keys": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Flat list of all i18n keys defined in this project."
          },
          "namespaces": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Top-level namespaces (first segment of dotted keys)."
          }
        },
        "additionalProperties": true
      }
    }
  }
}
