{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://f2x.local/schemas/specs-graph.schema.json",
  "title": "specs-graph",
  "description": "Knowledge graph of specs (functional in the workspace parent, technical/context per child repo).",
  "type": "object",
  "required": ["version", "builtAt", "nodes", "edges"],
  "properties": {
    "version": { "type": "string" },
    "builtAt": { "type": "string", "format": "date-time" },
    "workspace": { "type": "string" },
    "domain": { "type": ["string", "null"] },
    "parent": { "type": ["string", "null"] },
    "flowReadme": { "type": ["string", "null"] },
    "summary": { "type": "object", "additionalProperties": true },
    "contracts": { "type": "array", "items": { "type": "string" } },
    "flows": {
      "type": "array",
      "items": { "$ref": "#/$defs/flowDefinition" }
    },
    "nodes": {
      "type": "array",
      "items": { "$ref": "#/$defs/specNode" }
    },
    "edges": {
      "type": "array",
      "items": { "$ref": "#/$defs/specEdge" }
    }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": ["schema_version", "generated_at", "indexer"],
      "properties": {
        "schema_version": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "git_sha": { "type": ["string", "null"] },
        "indexer": { "type": "string" },
        "indexer_version": { "type": "string" },
        "stale": { "type": "boolean", "default": false }
      },
      "additionalProperties": true
    },
    "flowDefinition": {
      "type": "object",
      "required": ["key"],
      "properties": {
        "key": { "type": "string" },
        "name": { "type": ["string", "null"] },
        "summary": { "type": ["string", "null"] },
        "states": { "type": ["string", "null"] },
        "entities": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": ["string", "null"] },
        "definedIn": { "type": "string" },
        "specs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "specNode": {
      "type": "object",
      "required": ["id", "file", "type"],
      "properties": {
        "id": { "type": "string" },
        "file": { "type": "string" },
        "title": { "type": ["string", "null"] },
        "type": { "type": "string", "enum": ["functional", "technical", "context"] },
        "status": { "type": "string", "enum": ["draft", "approved", "in_progress", "implemented"] },
        "jira": { "type": ["string", "null"] },
        "repo": { "type": ["string", "null"] },
        "repos": { "type": "array", "items": { "type": "string" } },
        "refines": { "type": "array", "items": { "type": "string" } },
        "dependsOn": { "type": "array", "items": { "type": "string" } },
        "flows": { "type": "array", "items": { "type": "string" } },
        "flowDefinitions": { "type": "array", "items": { "$ref": "#/$defs/flowDefinition" } },
        "entities": { "type": "array", "items": { "type": "string" } },
        "endpoints": { "type": "array", "items": { "type": "string" } },
        "components": { "type": "array", "items": { "type": "string" } },
        "conditions": { "type": "array", "items": { "type": "string" } },
        "figmaUrls": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "url": { "type": "string" },
              "nodeId": { "type": ["string", "null"] },
              "mode": { "type": "string" }
            },
            "additionalProperties": true
          }
        },
        "figmaStatus": { "type": "string", "enum": ["ok", "incomplete", "missing", "n/a"] },
        "figmaWarnings": { "type": "array", "items": { "type": "string" } },
        "requiresUi": { "type": "boolean" },
        "acceptanceCount": { "type": "integer" },
        "hasFrontMatter": { "type": "boolean" }
      },
      "additionalProperties": true
    },
    "specEdge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": {
          "type": "string",
          "enum": ["depends_on", "refines", "shares_component", "shares_entity", "shares_endpoint"]
        },
        "attrs": { "type": "object", "additionalProperties": true },
        "weight": { "type": "number" }
      },
      "additionalProperties": true
    }
  }
}
