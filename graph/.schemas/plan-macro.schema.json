{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://f2x.local/schemas/plan-macro.schema.json",
  "title": "plan-macro",
  "description": "Standardized plan macro emitted by graph-agent before code generation. Required for both 'one HU' and 'full flow' modes.",
  "type": "object",
  "required": ["mode", "hu_id_or_flow", "files_to_touch", "tests_planned", "blockers", "approval_required"],
  "properties": {
    "schema_version": { "type": "string", "default": "0.4.0" },
    "mode": {
      "type": "string",
      "enum": ["one_hu", "full_flow", "discovery"]
    },
    "hu_id_or_flow": { "type": "string" },
    "summary": { "type": "string", "description": "1-3 sentences of what will be built." },
    "phases": {
      "type": "array",
      "description": "For full_flow mode: ordered phases. Each phase = group of HUs implementable together.",
      "items": {
        "type": "object",
        "required": ["name", "hus", "layers"],
        "properties": {
          "name": { "type": "string" },
          "hus": { "type": "array", "items": { "type": "string" } },
          "layers": { "type": "array", "items": { "enum": ["DS", "MFE", "Shell", "BFF"] } },
          "blockers": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "files_to_touch": {
      "type": "array",
      "description": "Files the agent expects to create/modify (relative paths).",
      "items": {
        "type": "object",
        "required": ["path", "action"],
        "properties": {
          "path": { "type": "string" },
          "action": { "type": "string", "enum": ["create", "modify", "delete"] },
          "reason": { "type": "string" }
        }
      }
    },
    "tests_planned": {
      "type": "array",
      "description": "Tests that will be written. Catches the agent if it forgets edge cases.",
      "items": {
        "type": "object",
        "required": ["file", "cases"],
        "properties": {
          "file": { "type": "string" },
          "cases": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "i18n_keys_used": {
      "type": "array",
      "description": "i18n keys the agent will reference. Must exist in graph/i18n-registry.json or be flagged as 'new'.",
      "items": {
        "type": "object",
        "required": ["key", "status"],
        "properties": {
          "key": { "type": "string" },
          "status": { "type": "string", "enum": ["exists", "new"] }
        }
      }
    },
    "contract_refs": {
      "type": "array",
      "description": "BFF endpoints / contract sections the agent will consume.",
      "items": { "type": "string" }
    },
    "blockers": {
      "type": "array",
      "description": "Issues that prevent implementation. If non-empty, agent must NOT proceed.",
      "items": {
        "type": "object",
        "required": ["severity", "reason"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "warning"] },
          "reason": { "type": "string" },
          "needs_from": { "type": "string", "enum": ["po", "design", "backend", "dev", "other"] }
        }
      }
    },
    "harness_commands": {
      "type": "array",
      "description": "Commands the agent will run after implementation.",
      "items": { "type": "string" }
    },
    "approval_required": {
      "type": "boolean",
      "const": true,
      "description": "Plan ALWAYS requires explicit 'aprobado' before code generation."
    },
    "estimated_tokens": { "type": "integer", "minimum": 0 }
  },
  "additionalProperties": true
}
