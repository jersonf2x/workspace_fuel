{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://f2x.local/schemas/flypass-graph.schema.json",
  "title": "flypass-graph",
  "description": "Cross-domain code knowledge graph: MFE remotes, Shell features, generic backend/frontend/infrastructure code, and cross-edges.",
  "type": "object",
  "required": ["_meta"],
  "properties": {
    "_meta": { "$ref": "https://f2x.local/schemas/specs-graph.schema.json#/$defs/meta" },
    "ds": {
      "type": "object",
      "properties": {
        "dsComponents": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "nodes": {
      "type": "array",
      "description": "Normalized code nodes across MFE, Shell and generic indexing. Generic repos populate this from backend/frontend/infrastructure slices.",
      "items": { "type": "object" }
    },
    "mfe": {
      "type": "object",
      "properties": {
        "mfeRemotes": { "type": "array", "items": { "type": "object" } },
        "consumedComponents": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "shell": {
      "type": "object",
      "properties": {
        "features": { "type": "array", "items": { "type": "object" } },
        "bridgeEvents": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "crossEdges": {
      "type": "array",
      "items": { "$ref": "#/$defs/crossEdge" }
    },
    "generic": {
      "type": "object",
      "description": "Generic repo graph for non-MFE/Shell repositories. Captures backend handlers/services, frontend components/API clients and infrastructure resources.",
      "additionalProperties": true
    }
  },
  "$defs": {
    "crossEdge": {
      "type": "object",
      "required": ["from", "to", "type"],
      "properties": {
        "from": { "type": "string" },
        "to": { "type": "string" },
        "type": {
          "type": "string",
          "enum": [
            "mfe_consumes_ds",
            "shell_hosts_mfe",
            "shell_emits_bridge",
            "mfe_consumes_bridge",
            "lambda_uses_service",
            "service_uses_schema",
            "service_uses_shared",
            "frontend_calls_endpoint",
            "infra_declares_lambda",
            "infra_declares_api",
            "infra_declares_iot_rule",
            "infra_declares_table"
          ]
        }
      },
      "additionalProperties": true
    }
  }
}
