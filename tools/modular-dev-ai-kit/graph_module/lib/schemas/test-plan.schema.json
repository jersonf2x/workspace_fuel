{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://f2x.local/schemas/test-plan.schema.json",
  "title": "test-plan",
  "description": "Plan de pruebas QA (salida de qa-analyzer-agent). G1 antes de qa-generator-agent.",
  "type": "object",
  "required": [
    "schema_version",
    "module",
    "status",
    "figma_node_ids",
    "screens",
    "critical_path",
    "scenarios",
    "approval_required"
  ],
  "properties": {
    "schema_version": { "type": "string", "const": "1.0.0" },
    "module": { "type": "string", "minLength": 1 },
    "status": { "type": "string", "enum": ["draft", "approved"] },
    "generated_at": { "type": "string" },
    "device_note": { "type": "string" },
    "figma_node_ids": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "screens": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["figma_node_id", "name", "mapping_status"],
        "properties": {
          "figma_node_id": { "type": "string" },
          "name": { "type": "string" },
          "mapping_status": { "type": "string", "enum": ["ok", "gap_visual", "partial"] }
        }
      }
    },
    "critical_path": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["flow", "risk"],
        "properties": {
          "flow": { "type": "string" },
          "risk": { "type": "string", "enum": ["high", "medium", "low"] },
          "rationale": { "type": "string" }
        }
      }
    },
    "scenarios": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scenario_name", "test_type", "screen", "expected_result"],
        "properties": {
          "scenario_name": { "type": "string" },
          "test_type": { "type": "string", "enum": ["positive", "negative", "edge"] },
          "screen": { "type": "string" },
          "precondition": { "type": "string" },
          "action": { "type": "string" },
          "expected_result": { "type": "string" },
          "data_fields": {
            "type": "array",
            "items": { "type": "string" }
          },
          "data_status": {
            "type": "string",
            "enum": ["ready", "missing", "new"]
          },
          "figma_node_id": { "type": "string" },
          "locator_android": { "type": "string" },
          "locator_ios": { "type": "string" },
          "locator_confidence": {
            "type": "string",
            "enum": ["high", "medium", "low"]
          }
        }
      }
    },
    "visual_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "element": { "type": "string" },
          "figma": { "type": "boolean" },
          "apk": { "type": "boolean" },
          "gap_type": { "type": "string" },
          "recommended_action": { "type": "string" }
        }
      }
    },
    "blockers": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["severity", "reason"],
        "properties": {
          "severity": { "type": "string", "enum": ["critical", "warning"] },
          "reason": { "type": "string" },
          "needs_from": { "type": "string" }
        }
      }
    },
    "approval_required": { "type": "boolean", "const": true }
  }
}
