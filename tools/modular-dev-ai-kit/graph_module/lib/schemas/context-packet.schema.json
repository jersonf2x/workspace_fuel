{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://f2x.local/schemas/context-packet.schema.json",
  "title": "context-packet",
  "description": "Bounded context packet returned to agents. Replaces raw slice with structured, provenance-rich envelope.",
  "type": "object",
  "required": ["intent", "snapshot", "freshness", "schema_version"],
  "properties": {
    "schema_version": { "type": "string" },
    "intent": {
      "type": "string",
      "enum": ["implement_hu", "plan_flow", "impact_analysis", "preflight", "review_pr"]
    },
    "snapshot": {
      "type": "object",
      "properties": {
        "git_sha": { "type": ["string", "null"] },
        "generated_at": { "type": "string", "format": "date-time" },
        "indexer_version": { "type": "string" }
      },
      "required": ["generated_at"],
      "additionalProperties": true
    },
    "freshness": { "type": "string", "enum": ["fresh", "stale", "unknown"] },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "tokens_estimated": { "type": "integer", "minimum": 0 },
    "hu_id": { "type": ["string", "null"] },
    "flow": { "type": ["string", "null"] },
    "primary_symbols": { "type": "array", "items": { "type": "string" } },
    "relevant_files": { "type": "array", "items": { "type": "string" } },
    "depends_on": { "type": "array", "items": { "type": "string" } },
    "shares_entity": { "type": "array", "items": { "type": "string" } },
    "shares_endpoint": { "type": "array", "items": { "type": "string" } },
    "shares_component": { "type": "array", "items": { "type": "string" } },
    "callers": { "type": "array", "items": { "type": "string" } },
    "tests": { "type": "array", "items": { "type": "string" } },
    "docs": { "type": "array", "items": { "type": "string" } },
    "bounded_slices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["file"],
        "properties": {
          "file": { "type": "string" },
          "lines": { "type": "string", "description": "Range like '120-180' or single line" },
          "reason": { "type": "string" }
        },
        "additionalProperties": true
      }
    },
    "figma": {
      "type": ["object", "null"],
      "properties": {
        "url": { "type": "string" },
        "node_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "warnings": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": true
}
